# ─────────────────────────────────────────────────────────────────────────────
# Neural-Trace — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Etherscan API Key ─────────────────────────────────────────────────────────
# Required — get a free key at https://etherscan.io/myapikey
# Free tier: 5 requests/sec, 100k calls/day
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the local web server (default: 8080)
NEURAL_TRACE_PORT=8080

# ── Authentication ────────────────────────────────────────────────────────────
# Browser will prompt for these credentials before granting access
# Change these to your own username and password
NEURAL_TRACE_USER=admin
NEURAL_TRACE_PASS=changeme

# ── Log Level ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
