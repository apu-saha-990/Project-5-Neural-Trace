# ─────────────────────────────────────────────────────────────────────────────
# Neural-Trace v2 — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Credentials & secrets ─────────────────────────────────────────────────────
.env

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.python-version

# ── Data — saved traces and reports ──────────────────────────────────────────
data/forward_trace/
data/origin_trace/
data/monitor/
data/reports/

# ── Temp files ────────────────────────────────────────────────────────────────
.monitor_input.json
.origin_input.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
